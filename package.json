{
  "name": "obsidian-front-matter-title",
  "version": "4.1.1",
  "description": "This is a sample plugin for Obsidian (https://obsidian.md)",
  "main": "main.js",
  "scripts": {
    "pack.beta": "node utils/pack-release.mjs beta",
    "pack.release": "node utils/pack-release.mjs release",
    "dev": "node utils/esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck -p ./tsconfig.build.json && node utils/esbuild.config.mjs production",
    "version": "node utils/version-bump.mjs && git add manifest.json versions.json",
    "test": "jest",
    "test:e2e": "wdio run ./wdio.conf.mts",
    "shots": "wdio run ./wdio.shots.mts",
    "frame": "node tools/screenshots/frame.mjs",
    "shots:pretty": "npm run shots && npm run frame",
    "eslint": "eslint src",
    "pretty": "prettier --write *.ts *.json src test --ignore-path package-lock.json"
  },
  "keywords": [],
  "author": "snezhig",
  "license": "MIT",
  "overrides": {
    "semver": ">=7.5.2",
    "serialize-javascript": ">=7.0.6",
    "diff": ">=8.0.3",
    "js-yaml": ">=4.1.2"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.0",
    "@wdio/cli": "^9.28.0",
    "@wdio/globals": "^9.28.0",
    "@wdio/local-runner": "^9.28.0",
    "@wdio/mocha-framework": "^9.28.0",
    "@wdio/spec-reporter": "^9.28.0",
    "adm-zip": "^0.5.17",
    "builtin-modules": "^5.2.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-mock-extended": "^4.0.1",
    "mocha": "^11.7.6",
    "obsidian": "^1.13.1",
    "obsidian-launcher": "^3.1.1",
    "prettier": "^3.8.4",
    "sharp": "^0.35.2",
    "ts-debounce": "^5.0.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "wdio-obsidian-reporter": "^3.1.1",
    "wdio-obsidian-service": "^3.1.1",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "i18next": "^26.3.2",
    "inversify": "^6.2.2",
    "reflect-metadata": "^0.2.2"
  }
}
